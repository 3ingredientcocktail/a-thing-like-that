---
import { getCollection } from 'astro:content';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const tagSlug = (tag) => encodeURIComponent(tag);
  const posts = await getCollection('blog');
  const sortedPosts = posts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  const tags = [...new Set(sortedPosts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag: tagSlug(tag) },
    props: {
      tag,
      posts: sortedPosts.filter((post) => post.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => {
  const cleanPath = path.replace(/^\/+/, '');
  return cleanPath ? `${base}/${cleanPath}` : `${base}/`;
};
const tagSlug = (value) => encodeURIComponent(value);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>#{tag} | Pablo’s Blog</title>
  </head>
  <body>
    <main class="container">
      <nav class="nav-row page-nav" aria-label="Site links">
        <a href={url('')}>blog</a>
        <a href={url('about/')}>about</a>
        <a
          class="external-link"
          href="https://github.com/3ingredientcocktail"
          target="_blank"
          rel="noreferrer noopener"
        >github</a>
        <a
          class="external-link"
          href="https://www.linkedin.com/in/zamoranop/"
          target="_blank"
          rel="noreferrer noopener"
        >linkedin</a>
        <a
          class="external-link"
          href="https://www.instagram.com/3ingredientcocktail/"
          target="_blank"
          rel="noreferrer noopener"
        >instagram</a>
        <a
          class="external-link"
          href="https://open.spotify.com/user/zamoranop"
          target="_blank"
          rel="noreferrer noopener"
        >spotify</a>
      </nav>

      <header class="site-header">
        <p class="eyebrow">Posts tagged</p>
        <h1>#{tag}</h1>
      </header>

      <section aria-labelledby="tag-posts-heading">
        <h2 class="section-label" id="tag-posts-heading">Posts</h2>
        <ul class="feed">
          {posts.map((post) => (
            <li class="post-item">
              <article>
                <a
                  class="post-title"
                  href={url(`/posts/${post.id.replace(/\.md$/, '')}`)}
                >
                  {post.data.title}
                </a>

                <div class="meta">
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </div>

                <div class="tag-list">
                  {post.data.tags.map((postTag) => (
                    <a class="tag" href={url(`/tags/${tagSlug(postTag)}/`)}>
                      #{postTag}
                    </a>
                  ))}
                </div>
              </article>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
