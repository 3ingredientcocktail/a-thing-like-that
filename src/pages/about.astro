---
import '../styles/blog.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => {
  const cleanPath = path.replace(/^\/+/, '');
  return cleanPath ? `${base}/${cleanPath}` : `${base}/`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>About | Pablo Zamorano-Torres</title>
  </head>
  <body>
    <main class="container">
      <header class="page-hero">
        <h1 class="page-title">
          <span class="title-line">Pablo</span>
          <span class="title-line">Zamorano‑Torres</span>
        </h1>
        <p class="home-subtitle">
          Third culture kid, born in the US to Chilean parents doing grad
          school.
        </p>

        <nav class="nav-row page-nav" aria-label="Site links">
          <a href={url('')}>blog</a>
          <a href={url('about/')} aria-current="page">about</a>
          <a
            class="external-link"
            href="https://github.com/3ingredientcocktail"
            target="_blank"
            rel="noreferrer noopener"
          >github</a>
          <a
            class="external-link"
            href="https://www.linkedin.com/in/zamoranop/"
            target="_blank"
            rel="noreferrer noopener"
          >linkedin</a>
          <a
            class="external-link"
            href="https://www.instagram.com/3ingredientcocktail/"
            target="_blank"
            rel="noreferrer noopener"
          >instagram</a>
          <a
            class="external-link"
            href="https://open.spotify.com/user/zamoranop"
            target="_blank"
            rel="noreferrer noopener"
          >spotify</a>
        </nav>
      </header>

      <section class="home-blurb">
        <p>
          I’m a Chilean-American product person, analyst, and teacher currently
          based in Chile. I’ve worked across tech, data, hospitality, and
          education — from product management in the Bay Area to teaching
          English in Concepción — and I’m interested in how people move through
          culture, institutions, and different systems (disenchanted
          econ/rational expectations major).
        </p>
        <p>
          My current goal is to move to NYC and explore the northeast, or return
          to lovely SF. 🌁
        </p>
      </section>
    </main>
  </body>
</html>
