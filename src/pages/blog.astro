---
import '../styles/blog.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => {
  const cleanPath = path.replace(/^\/+/, '');
  return cleanPath ? `${base}/${cleanPath}` : `${base}/`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog moved | Pablo’s Blog</title>
  </head>
  <body>
    <main class="container">
      <header class="site-header">
        <h1>Blog moved</h1>
        <p class="lede">
          The blog now lives at <a href={url('')}>/</a>.
        </p>
      </header>

      <nav class="nav-row page-nav" aria-label="Site links">
        <a href={url('')}>blog</a>
        <a href={url('about/')}>about</a>
        <a
          href="https://github.com/3ingredientcocktail"
          target="_blank"
          rel="noreferrer"
        >
          github
        </a>
        <a
          href="https://www.linkedin.com/in/zamoranop/"
          target="_blank"
          rel="noreferrer"
        >
          linkedin
        </a>
        <a
          href="https://www.instagram.com/3ingredientcocktail/"
          target="_blank"
          rel="noreferrer"
        >
          instagram
        </a>
        <a
          href="https://open.spotify.com/user/zamoranop"
          target="_blank"
          rel="noreferrer"
        >
          spotify
        </a>
      </nav>
    </main>
  </body>
</html>
