---
import '../styles/blog.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => {
  const cleanPath = path.replace(/^\/+/, '');
  return cleanPath ? `${base}/${cleanPath}` : `${base}/`;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pablo Zamorano-Torres</title>
  </head>
  <body>
    <main class="container">
      <header class="page-hero">
        <h1 class="page-title">
          <span class="title-line">Pablo</span>
          <span class="title-line">Zamorano‑Torres</span>
        </h1>
        <p class="home-subtitle">
          A short bio placeholder about what I make, write, and care about.
        </p>

        <nav class="nav-row page-nav" aria-label="Site links">
          <a href={url('')}>home</a>
          <a href={url('blog/')}>blog</a>
          <a
            href="https://github.com/3ingredientcocktail"
            target="_blank"
            rel="noreferrer"
          >
            github
          </a>
          <!-- TODO: Replace with the real LinkedIn URL. -->
          <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">
            linkedin
          </a>
          <!-- TODO: Replace with the real Instagram URL. -->
          <a href="https://www.instagram.com/" target="_blank" rel="noreferrer">
            instagram
          </a>
          <!-- TODO: Replace with the real Spotify URL. -->
          <a href="https://open.spotify.com/" target="_blank" rel="noreferrer">
            spotify
          </a>
        </nav>
      </header>

      <section class="home-blurb">
        <p>
          This is a short placeholder blurb for the homepage. I’ll use this
          space for a personal note, a few current interests, or a tiny
          snapshot of what I’m working on.
        </p>
      </section>
    </main>
  </body>
</html>
